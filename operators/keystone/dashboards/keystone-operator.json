{
  "uid": "keystone-operator",
  "title": "Keystone Operator",
  "tags": ["keystone", "operator", "CC-0089"],
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "timezone": "",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Reconcile duration p95 per sub_reconciler",
      "description": "p95 wall-clock duration of Keystone sub-reconciler invocations, derived from keystone_operator_reconcile_duration_seconds_bucket (CC-0089, REQ-001).",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, sub_reconciler) (rate(keystone_operator_reconcile_duration_seconds_bucket[5m])))",
          "legendFormat": "{{sub_reconciler}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Reconcile error rate per condition_type",
      "description": "Rate of keystone_operator_reconcile_errors_total grouped by condition_type (CC-0089, REQ-002).",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (condition_type) (rate(keystone_operator_reconcile_errors_total[5m]))",
          "legendFormat": "{{condition_type}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Key rotation age per keystone + key_type",
      "description": "Age in seconds of the most recent successful key rotation, per Keystone CR and key_type (CC-0089, REQ-003).",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "keystone_operator_key_rotation_age_seconds",
          "legendFormat": "{{namespace}}/{{keystone}} {{key_type}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "db_sync duration p95 and failure rate",
      "description": "Target A: p95 of keystone_operator_db_sync_duration_seconds_bucket per Keystone CR. Target B: failure rate of keystone_operator_db_sync_total{result=\"failed\"} (CC-0089, REQ-005).",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "^failures .*"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ops"
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, namespace, keystone) (rate(keystone_operator_db_sync_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{namespace}}/{{keystone}}"
        },
        {
          "refId": "B",
          "expr": "sum by (namespace, keystone) (rate(keystone_operator_db_sync_total{result=\"failed\"}[5m]))",
          "legendFormat": "failures {{namespace}}/{{keystone}}"
        }
      ]
    }
  ]
}
