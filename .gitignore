.claude/*
!.claude/skills/
.planwerk/.secrets.toml
.serena

# Go build artifacts
bin/
vendor/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Operator binaries (built by `go build`)
operators/keystone/keystone
operators/c5c3/c5c3

# Go workspace — go.work.sum is tracked for reproducibility.

# IDE
.idea/
.vscode/
*.swp
*.swo

# Node.js / VitePress
node_modules/
docs/.vitepress/cache/
docs/.vitepress/dist/

# Collected CI evidence (debug-e2e-failure log excerpts, downloaded artifacts)
# and other generated local output.
_output/

# Local developer scratch — throwaway CRs kept out of version control. Bare
# names match by basename in any directory; already-tracked manifests such as
# deploy/kind/controlplane/controlplane.yaml stay tracked regardless.
keystone.yaml
keystone-ca.crt
controlplane.yaml
cp2.yml
demo/

# Key material / credentials — never commit private keys or client bundles
# (e.g. the OpenBao mTLS openbao-client.p12). Use `git add -f` for the rare
# fixture that is meant to be tracked.
*.p12
*.pem
*.key
*.pfx

# Build artifact: copied at deploy time from operators/keystone/dashboards/
# (WITH_PROMETHEUS=true) so kustomize's configMapGenerator can reference it from
# the overlay root without a `../../` parent traversal (LoadRestrictionsRootOnly).
deploy/kind/prometheus/keystone-operator.json

# Vendored Helm subchart dependencies. The operator charts depend on the
# operator-library library chart via a file:// path; `helm dependency build`
# vendors it into charts/ from that local source. Chart.lock is committed; the
# vendored copy is a build artifact regenerated by `make helm-deps`.
operators/keystone/helm/keystone-operator/charts/
operators/c5c3/helm/c5c3-operator/charts/
operators/horizon/helm/horizon-operator/charts/
__pycache__/
